generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberTier {
  MEMBER
  VIP

  @@map("member_tier")
}

enum UserStatus {
  ACTIVE
  BLOCKED

  @@map("user_status")
}

enum ClubCardStatus {
  ACTIVE
  REVOKED
  EXPIRED

  @@map("club_card_status")
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED

  @@map("subscription_status")
}

enum SubscriptionKind {
  VIP_MEMBERSHIP
  BUSINESS_PLACEMENT

  @@map("subscription_kind")
}

enum BusinessStatus {
  UNDER_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
  HIDDEN

  @@map("business_status")
}

enum IntroductionStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  COMPLETED
  REJECTED
  CANCELED

  @@map("introduction_status")
}

enum StaffRole {
  OWNER
  ADMIN
  MODERATOR
  SUPPORT

  @@map("staff_role")
}

model User {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supabase_auth_user_id String?                @unique @db.Uuid
  phone                 String                 @unique @db.VarChar(32)
  display_name          String?                @db.VarChar(100)
  locale_preference     String?                @db.VarChar(2)
  membership_tier       MemberTier             @default(MEMBER)
  status                UserStatus             @default(ACTIVE)
  terms_accepted_at     DateTime?
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt
  member_cards          MemberCard[]
  vip_subscriptions     VipSubscription[]
  subscriptions         Subscription[]
  business_profiles     BusinessProfile[]
  requested_intros      BusinessIntroduction[] @relation("requester_user")

  @@index([status, created_at])
  @@map("users")
}

model MemberCard {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String         @db.Uuid
  user            User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  card_number     String         @unique @db.VarChar(16)
  membership_tier MemberTier
  status          ClubCardStatus @default(ACTIVE)
  qr_payload_url  String?        @db.Text
  issued_at       DateTime       @default(now())
  expires_at      DateTime?
  revoked_at      DateTime?
  revoked_reason  String?        @db.Text
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  @@index([user_id, issued_at])
  @@index([status, expires_at])
  @@map("member_cards")
}

model VipSubscription {
  id                     String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String             @db.Uuid
  user                   User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  status                 SubscriptionStatus @default(NONE)
  stripe_customer_id     String?            @db.VarChar(255)
  stripe_subscription_id String?            @unique @db.VarChar(255)
  stripe_price_id        String?            @db.VarChar(255)
  current_period_start   DateTime?
  current_period_end     DateTime?
  cancel_at_period_end   Boolean            @default(false)
  canceled_at            DateTime?
  expires_at             DateTime?
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt

  @@index([user_id, status, current_period_end])
  @@map("vip_subscriptions")
}

model Subscription {
  id                     String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String?            @db.Uuid
  user                   User?              @relation(fields: [user_id], references: [id], onDelete: SetNull)
  business_profile_id    String?            @db.Uuid
  business_profile       BusinessProfile?   @relation(fields: [business_profile_id], references: [id], onDelete: SetNull)
  kind                   SubscriptionKind
  status                 SubscriptionStatus @default(NONE)
  stripe_customer_id     String?            @db.VarChar(255)
  stripe_subscription_id String?            @unique @db.VarChar(255)
  stripe_price_id        String?            @db.VarChar(255)
  current_period_start   DateTime?
  current_period_end     DateTime?
  cancel_at_period_end   Boolean            @default(false)
  canceled_at            DateTime?
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt

  @@index([user_id, kind, status, current_period_end])
  @@index([business_profile_id, kind, status, current_period_end])
  @@map("subscriptions")
}

model Category {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String            @unique @db.VarChar(120)
  slug              String            @unique @db.VarChar(120)
  is_high_risk      Boolean           @default(false)
  is_active         Boolean           @default(true)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  business_profiles BusinessProfile[]

  @@index([is_high_risk, is_active])
  @@map("categories")
}

model Country {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code2      String            @unique @db.Char(2)
  code3      String?           @unique @db.Char(3)
  name       String            @db.VarChar(120)
  slug       String            @unique @db.VarChar(120)
  is_active  Boolean           @default(true)
  created_at DateTime          @default(now())
  updated_at DateTime          @updatedAt
  cities     City[]
  businesses BusinessProfile[]

  @@index([is_active, name])
  @@map("countries")
}

model City {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  country_id String            @db.Uuid
  country    Country           @relation(fields: [country_id], references: [id], onDelete: Cascade)
  name       String            @db.VarChar(120)
  slug       String            @db.VarChar(120)
  is_active  Boolean           @default(true)
  created_at DateTime          @default(now())
  updated_at DateTime          @updatedAt
  businesses BusinessProfile[]

  @@unique([country_id, slug])
  @@index([country_id, is_active, name])
  @@map("cities")
}

model BusinessProfile {
  id                     String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String                 @db.Uuid
  user                   User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  slug                   String                 @unique @db.VarChar(140)
  name                   String                 @db.VarChar(100)
  representative_name    String                 @db.VarChar(100)
  representative_email   String                 @db.VarChar(255)
  representative_phone   String                 @db.VarChar(32)
  country_id             String                 @db.Uuid
  country                Country                @relation(fields: [country_id], references: [id], onDelete: Restrict)
  city_id                String                 @db.Uuid
  city                   City                   @relation(fields: [city_id], references: [id], onDelete: Restrict)
  category_id            String                 @db.Uuid
  category               Category               @relation(fields: [category_id], references: [id], onDelete: Restrict)
  status                 BusinessStatus         @default(UNDER_REVIEW)
  website_url            String?                @db.Text
  social_url             String?                @db.Text
  brief_description      String?                @db.VarChar(500)
  description            String?                @db.Text
  featured_top           Boolean                @default(false)
  featured_recommended   Boolean                @default(false)
  internal_notes         String?                @db.Text
  rejection_reason       String?                @db.Text
  approved_at            DateTime?
  published_at           DateTime?
  hidden_at              DateTime?
  rejected_at            DateTime?
  created_at             DateTime               @default(now())
  updated_at             DateTime               @updatedAt
  subscriptions          Subscription[]
  outgoing_introductions BusinessIntroduction[] @relation("requester_business")
  incoming_introductions BusinessIntroduction[] @relation("target_business")

  @@index([status, created_at])
  @@index([status, featured_top, featured_recommended, category_id])
  @@index([status, country_id, city_id, category_id, published_at])
  @@map("business_profiles")
}

model BusinessIntroduction {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requester_user_id     String             @db.Uuid
  requester_user        User               @relation("requester_user", fields: [requester_user_id], references: [id], onDelete: Cascade)
  requester_business_id String             @db.Uuid
  requester_business    BusinessProfile    @relation("requester_business", fields: [requester_business_id], references: [id], onDelete: Cascade)
  target_business_id    String             @db.Uuid
  target_business       BusinessProfile    @relation("target_business", fields: [target_business_id], references: [id], onDelete: Cascade)
  status                IntroductionStatus @default(SUBMITTED)
  message               String?            @db.Text
  rejection_reason      String?            @db.Text
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt

  @@index([requester_user_id, status, created_at])
  @@index([requester_business_id, target_business_id, status, created_at])
  @@index([target_business_id, status, created_at])
  @@map("business_introductions")
}

model AdminUser {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone            String         @unique @db.VarChar(32)
  role             StaffRole
  display_name     String?        @db.VarChar(100)
  is_active        Boolean        @default(true)
  totp_verified_at DateTime?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  two_factor       Admin2FA?
  sessions         AdminSession[]
  audit_logs       AuditLog[]
  updated_configs  AdminConfig[] @relation("admin_config_updated_by")

  @@index([role, is_active, created_at])
  @@map("admin_users")
}

model Admin2FA {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  admin_user_id       String    @unique @db.Uuid
  admin_user          AdminUser @relation(fields: [admin_user_id], references: [id], onDelete: Cascade)
  secret_ciphertext   String    @db.Text
  backup_codes_hashes Json?
  verified_at         DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@map("admin_2fa")
}

model AdminSession {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  admin_user_id      String    @db.Uuid
  admin_user         AdminUser @relation(fields: [admin_user_id], references: [id], onDelete: Cascade)
  session_token_hash String    @unique @db.Text
  ip_address         String?   @db.VarChar(64)
  user_agent         String?   @db.Text
  expires_at         DateTime
  last_seen_at       DateTime?
  revoked_at         DateTime?
  created_at         DateTime  @default(now())

  @@index([admin_user_id, expires_at])
  @@index([expires_at, revoked_at])
  @@map("admin_sessions")
}

model AuditLog {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_staff_id String?    @db.Uuid
  actor_staff    AdminUser? @relation(fields: [actor_staff_id], references: [id], onDelete: SetNull)
  actor_role     StaffRole?
  action         String     @db.VarChar(120)
  entity_type    String     @db.VarChar(120)
  entity_id      String     @db.Text
  before_data    Json?
  after_data     Json?
  metadata       Json?
  ip_address     String?    @db.VarChar(64)
  created_at     DateTime   @default(now())

  @@index([actor_staff_id, created_at])
  @@index([entity_type, entity_id, created_at])
  @@index([action, created_at])
  @@map("audit_logs")
}

model AdminConfig {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key                 String     @unique @db.VarChar(120)
  value               Json
  description         String?    @db.Text
  updated_by_staff_id String?    @db.Uuid
  updated_by_staff    AdminUser? @relation("admin_config_updated_by", fields: [updated_by_staff_id], references: [id], onDelete: SetNull)
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  @@index([key])
  @@map("admin_config")
}

model StripeWebhookEvent {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id       String    @unique @db.VarChar(255)
  event_type     String    @db.VarChar(120)
  handler_status String    @default("RECEIVED") @db.VarChar(32)
  livemode       Boolean   @default(false)
  payload        Json
  error_message  String?   @db.Text
  processed_at   DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@index([handler_status, created_at])
  @@index([event_type, created_at])
  @@map("stripe_webhook_events")
}
