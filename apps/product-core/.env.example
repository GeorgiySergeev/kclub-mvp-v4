# Product Core Environment Variables Placeholder
# See docs/ENVIRONMENT.md for the full list of required secrets in production
# Copy this file to `.env.local` and fill in the values.

# Base URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_APP_URL=http://localhost:3001

# Staff auth bootstrap for the first OWNER.
ADMIN_BOOTSTRAP_OWNER_PHONE=+15551234567
ADMIN_JWT_SECRET=aJVdGsUNhb3t5mgxM9P7BBDkW98cJZfK1c04Am2ZOAt

# Local staff-auth development codes. Replace with real SMS/TOTP providers before launch.
ADMIN_STAFF_DEV_OTP=000000
ADMIN_STAFF_DEV_TOTP=123456

# Database
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kclub

# Third Party
# STRIPE_SECRET_KEY=sk_test_...
# SUPABASE_URL=https://...
# SUPABASE_SERVICE_ROLE_KEY=ey...

NEXT_PUBLIC_APP_URL=              
NEXT_PUBLIC_SUPABASE_URL=          
NEXT_PUBLIC_SUPABASE_ANON_KEY=     
SUPABASE_SERVICE_ROLE_KEY=         
SUPABASE_JWT_SECRET=               
STRIPE_SECRET_KEY=                
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=             
CRON_SECRET=                       
ADMIN_APP_URL=                     
ADMIN_BOOTSTRAP_OWNER_PHONE=
ADMIN_JWT_SECRET=
ADMIN_STAFF_DEV_OTP=
ADMIN_STAFF_DEV_TOTP=
EMAIL_PROVIDER_API_KEY=            
EMAIL_FROM_ADDRESS=                
LOG_LEVEL=                         



# App

NODE_ENV=development

# Database - Supabase Postgres via Drizzle
DATABASE_URL=postgres://postgres:REPLACE_ME@db.REPLACE_ME.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL_DIRECT=postgres://postgres:REPLACE_ME@db.REPLACE_ME.supabase.co:5432/postgres
# Optional. Disposable DB only for `pnpm test:db`; database name must contain test, ci, or scratch.
TEST_DATABASE_URL=

# Authentication - Supabase Auth phone-first
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_ME.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Local/demo only. Production rejects this flag even if it is set.
AUTH_DEV_PHONE_BYPASS_ENABLED=
# Required only when the dev phone bypass flag is enabled outside tests.
# AUTH_DEV_PHONE_BYPASS_SECRET=REPLACE_ME_WITH_RANDOM_32_BYTES
AUTH_DEV_2FA_BYPASS_ENABLED=

# Billing - Stripe
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_VIP_ANNUAL=price_REPLACE_ME
STRIPE_PRICE_BUSINESS_ANNUAL=price_REPLACE_ME
STRIPE_PORTAL_CONFIGURATION_ID=bpc_REPLACE_ME

# Vercel Cron (daily Stripe reconciliation)
# CRON_SECRET=REPLACE_ME

# Rate limiting - Upstash
UPSTASH_REDIS_REST_URL=https://REPLACE_ME.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_ME

# Bot defense - Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAREPLACE_ME
TURNSTILE_SECRET_KEY=0x4AAAAAAAREPLACE_ME

# Observability - Sentry
NEXT_PUBLIC_SENTRY_DSN=https://REPLACE_ME@oREPLACE_ME.ingest.sentry.io/REPLACE_ME
SENTRY_ORG=kclub
SENTRY_PROJECT=kclub-web
# SENTRY_AUTH_TOKEN=sntrys_REPLACE_ME

# Analytics - Plausible
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=kclub.example.com

# Email - optional at MVP
# RESEND_API_KEY=re_REPLACE_ME
# EMAIL_FROM="KCLUB <hello@kclub.example.com>"
# SUBSCRIBE_WEBHOOK_URL=https://hooks.example.com/subscribe
# SUBSCRIBE_API_KEY=REPLACE_ME   # optional bearer token for subscribe webhook

# Internal flags
ALLOW_SEED=
CONFIRM_SEED=
DISABLE_VOCAB_GREP=

# E2E Testing — enables test seed/teardown API routes (never set in production)
# E2E_TEST_SECRET=
